{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-game",
      "type": "shell",
      "command": "dotnet",
      "options": {
        "env": {
          "DYLD_LIBRARY_PATH": "${env:HOME}/.local/lib:/opt/homebrew/opt/freetype/lib:${env:DYLD_LIBRARY_PATH}"
        }
      },
      "args": [
        "build",
        "src/BaseballManager.Game/BaseballManager.Game.csproj"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "run-game",
      "type": "shell",
      "command": "dotnet",
      "options": {
        "env": {
          "DYLD_LIBRARY_PATH": "${env:HOME}/.local/lib:/opt/homebrew/opt/freetype/lib:${env:DYLD_LIBRARY_PATH}"
        }
      },
      "args": [
        "run",
        "--project",
        "src/BaseballManager.Game/BaseballManager.Game.csproj"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
